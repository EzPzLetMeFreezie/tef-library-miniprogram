.login-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  background: linear-gradient(180deg, #4A90D9 0%, #357ABD 50%, #f5f6fa 100%);
  padding: 0 60rpx;
}

.login-lang-btn {
  margin-top: 32rpx;
  height: 52rpx;
  padding: 0 32rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-lang-text {
  font-size: 24rpx;
  color: #fff;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.logo-img {
  width: 180rpx;
  height: 180rpx;
  border-radius: 36rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
}

.app-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.app-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.login-body {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* Profile section */
.profile-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
}

.avatar-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: transparent;
  border: none;
  padding: 0;
  margin-bottom: 24rpx;
  line-height: normal;
}

.avatar-wrapper::after {
  border: none;
}

.avatar-preview {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.6);
  background: rgba(255, 255, 255, 0.2);
}

.avatar-hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 12rpx;
}

.nickname-field {
  width: 100%;
  max-width: 480rpx;
}

.nickname-input {
  height: 80rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 40rpx;
  padding: 0 32rpx;
  font-size: 30rpx;
  color: #fff;
  text-align: center;
}

/* Login button */
.login-btn {
  width: 100% !important;
  height: 96rpx;
  line-height: 96rpx;
  background: #fff;
  color: #4A90D9;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.login-btn::after {
  border: none;
}

.login-tip {
  margin-top: 32rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}
