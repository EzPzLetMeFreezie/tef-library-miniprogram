<view class="login-container">
  <view class="login-header">
    <image class="logo-img" src="/images/icon.jpg" mode="aspectFill"></image>
    <text class="app-title">TEF Library</text>
    <text class="app-subtitle">Thanksgiving English Fellowship</text>
  </view>

  <view class="login-body">
    <!-- Avatar chooser -->
    <view class="profile-section">
      <button class="avatar-wrapper" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image class="avatar-preview" src="{{avatarUrl || '/images/default-avatar.png'}}"></image>
        <text class="avatar-hint">{{avatarUrl ? i18n.avatarChange : i18n.avatarChoose}}</text>
      </button>
      <view class="nickname-field">
        <input type="nickname" class="nickname-input" placeholder="{{i18n.nicknamePlaceholder}}" value="{{nickname}}" bindinput="onNicknameInput" />
      </view>
    </view>

    <button class="login-btn" bindtap="handleLogin" loading="{{loading}}">
      <text>{{i18n.loginBtn}}</text>
    </button>
    <text class="login-tip">{{i18n.loginTip}}</text>
    <view class="login-lang-btn" bindtap="toggleLang">
      <text class="login-lang-text">{{i18n.langSwitch}}</text>
    </view>
  </view>
</view>
