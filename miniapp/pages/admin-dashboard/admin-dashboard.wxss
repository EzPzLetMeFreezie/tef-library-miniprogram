.admin-container {
  padding: 24rpx;
}

.dashboard-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.dashboard-logo {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  margin-right: 16rpx;
}

.dashboard-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.stat-card {
  text-align: center;
  padding: 28rpx 20rpx;
}

.stat-number {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #4A90D9;
  margin-bottom: 8rpx;
}

.stat-number.danger {
  color: #ff4d4f;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.menu-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 16rpx;
  display: block;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.menu-arrow {
  font-size: 36rpx;
  color: #ccc;
}
