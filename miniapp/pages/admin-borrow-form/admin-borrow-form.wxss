.form-container {
  padding: 24rpx;
  padding-bottom: 40rpx;
}

.form-group {
  padding: 24rpx;
  margin-bottom: 24rpx;
  position: relative;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.search-field {
  position: relative;
}

.search-input {
  font-size: 28rpx;
  color: #333;
  padding: 16rpx 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  width: 100%;
  box-sizing: border-box;
}

/* Selected item display */
.selected-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 20rpx;
  background: #e8f4fd;
  border-radius: 12rpx;
  border: 1rpx solid #4A90D9;
}

.selected-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.selected-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.selected-detail {
  font-size: 24rpx;
  color: #888;
  margin-top: 4rpx;
}

.clear-btn {
  font-size: 26rpx;
  color: #4A90D9;
  padding: 8rpx 16rpx;
  flex-shrink: 0;
}

/* Search results dropdown */
.search-results {
  margin-top: 8rpx;
  background: #fff;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  max-height: 400rpx;
  overflow-y: auto;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.result-item {
  display: flex;
  flex-direction: column;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.result-item:last-child {
  border-bottom: none;
}

.result-item:active {
  background: #f0f7ff;
}

.result-name {
  font-size: 28rpx;
  color: #333;
}

.result-detail {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.no-results {
  margin-top: 8rpx;
  padding: 20rpx;
  text-align: center;
  font-size: 26rpx;
  color: #999;
}

/* Date picker */
.date-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
}

.date-value {
  font-size: 30rpx;
  color: #333;
}

.date-hint {
  font-size: 24rpx;
  color: #999;
}

/* Submit button */
.submit-btn {
  margin-top: 32rpx;
  width: 100%;
}
