.admin-categories-container {
  padding: 24rpx;
}

.add-section {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.add-input {
  flex: 1;
  height: 72rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.category-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
}

.category-info {
  flex: 1;
}

.category-name {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.category-count {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.category-actions {
  display: flex;
  gap: 24rpx;
  flex-shrink: 0;
}

.action-edit {
  font-size: 26rpx;
  color: #4A90D9;
}

.action-delete {
  font-size: 26rpx;
  color: #ff4d4f;
}
