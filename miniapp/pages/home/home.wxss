.home-container {
  padding: 0 0 140rpx;
  background: #f7f7f7;
  min-height: 100vh;
}

/* Top Header */
.top-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 32rpx 16rpx;
}

.date-info {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.date-day {
  font-size: 56rpx;
  font-weight: 300;
  color: #1a1a1a;
  line-height: 1;
}

.date-detail {
  display: flex;
  flex-direction: column;
}

.date-weekday {
  font-size: 22rpx;
  color: #999;
  font-weight: 500;
}

.date-month {
  font-size: 22rpx;
  color: #999;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.lang-btn {
  height: 52rpx;
  padding: 0 20rpx;
  background: #1a1a1a;
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.lang-text {
  font-size: 22rpx;
  color: #fff;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.admin-badge {
  width: 60rpx;
  height: 60rpx;
  border-radius: 14rpx;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.admin-badge-icon {
  font-size: 32rpx;
  color: #666;
}

.header-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #e0e0e0;
}

/* Section */
.section {
  margin-top: 24rpx;
  padding: 0 32rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.section-more {
  font-size: 24rpx;
  color: #e8734a;
  font-weight: 500;
}

/* Book Scroll */
.book-scroll {
  white-space: nowrap;
  margin: 0 -32rpx;
  padding: 0 32rpx;
}

.book-scroll-item {
  display: inline-block;
  width: 240rpx;
  margin-right: 24rpx;
  vertical-align: top;
}

.book-cover-card {
  width: 240rpx;
  height: 320rpx;
  border-radius: 16rpx;
  background: #e8e8e8;
}

.book-card-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-top: 14rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.book-card-author {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* My Books */
.my-books-section {
  margin-top: 32rpx;
}

.my-book-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.my-book-cover {
  width: 100rpx;
  height: 140rpx;
  border-radius: 10rpx;
  background: #e8e8e8;
  flex-shrink: 0;
}

.my-book-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.my-book-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.my-book-author {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.my-book-due {
  font-size: 22rpx;
  color: #e8734a;
  margin-top: 12rpx;
  font-weight: 500;
}

.my-book-due.overdue {
  color: #ff4d4f;
}

.my-book-dots {
  font-size: 36rpx;
  color: #ccc;
  padding: 0 12rpx;
}

/* Empty */
.empty-text {
  text-align: center;
  color: #999;
  padding: 120rpx 0;
  font-size: 28rpx;
}
