.home-container {
  padding-bottom: 20rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  margin: 20rpx 24rpx;
  padding: 20rpx 28rpx;
  background: #fff;
  border-radius: 40rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.search-icon {
  margin-right: 16rpx;
  font-size: 32rpx;
}

.search-placeholder {
  color: #bbb;
  font-size: 28rpx;
}

.banner {
  margin: 0 24rpx 24rpx;
  height: 240rpx;
  background: linear-gradient(135deg, #4A90D9, #6FB1FC);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  padding: 0 40rpx;
}

.banner-logo {
  width: 120rpx;
  height: 120rpx;
  border-radius: 24rpx;
  margin-right: 28rpx;
  flex-shrink: 0;
}

.banner-content {
  display: flex;
  flex-direction: column;
}

.banner-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
}

.banner-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.admin-entry {
  display: flex;
  align-items: center;
  margin: 0 24rpx 24rpx;
  padding: 24rpx 28rpx;
}

.admin-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.admin-text {
  flex: 1;
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.admin-arrow {
  font-size: 36rpx;
  color: #ccc;
}

.section {
  margin: 0 24rpx 32rpx;
}

.book-scroll {
  white-space: nowrap;
  padding: 8rpx 0;
}

.book-scroll-item {
  display: inline-block;
  width: 200rpx;
  margin-right: 20rpx;
  vertical-align: top;
}

.book-cover-small {
  width: 200rpx;
  height: 260rpx;
  border-radius: 12rpx;
  background: #e8e8e8;
}

.book-title-small {
  display: block;
  font-size: 24rpx;
  font-weight: 500;
  color: #333;
  margin-top: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.book-author-small {
  display: block;
  font-size: 22rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.book-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.book-grid-item {
  width: calc(33.33% - 14rpx);
}

.book-cover-grid {
  width: 100%;
  height: 280rpx;
  border-radius: 12rpx;
  background: #e8e8e8;
}

.book-title-grid {
  display: block;
  font-size: 24rpx;
  font-weight: 500;
  color: #333;
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.book-author-grid {
  display: block;
  font-size: 22rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
