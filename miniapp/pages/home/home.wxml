<view class="home-container">
  <!-- Top Header: Date + Avatar -->
  <view class="top-header">
    <view class="date-info">
      <text class="date-day">{{dateDay}}</text>
      <view class="date-detail">
        <text class="date-weekday">{{dateWeekday}}</text>
        <text class="date-month">{{dateMonth}}</text>
      </view>
    </view>
    <view class="header-right">
      <view class="admin-badge" wx:if="{{isAdmin}}" bindtap="goAdmin">
        <text class="admin-badge-icon">⚙</text>
      </view>
      <image class="header-avatar" src="{{userInfo.avatarUrl || '/images/icon.jpg'}}" mode="aspectFill" bindtap="goProfile"></image>
    </view>
  </view>

  <!-- New Arrivals Section -->
  <view class="section" wx:if="{{newArrivals.length > 0}}">
    <view class="section-head">
      <text class="section-title">New arrivals</text>
      <text class="section-more" bindtap="goBooks">View all ></text>
    </view>
    <scroll-view scroll-x class="book-scroll" enhanced show-scrollbar="{{false}}">
      <view class="book-scroll-item" wx:for="{{newArrivals}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
        <image class="book-cover-card" src="{{item.coverUrl || '/images/default-cover.png'}}" mode="aspectFill"></image>
        <text class="book-card-title">{{item.title}}</text>
        <text class="book-card-author">{{item.author}}</text>
      </view>
    </scroll-view>
  </view>

  <!-- Hot Books Section -->
  <view class="section" wx:if="{{hotBooks.length > 0}}">
    <view class="section-head">
      <text class="section-title">Popular books</text>
      <text class="section-more" bindtap="goBooks">View all ></text>
    </view>
    <scroll-view scroll-x class="book-scroll" enhanced show-scrollbar="{{false}}">
      <view class="book-scroll-item" wx:for="{{hotBooks}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
        <image class="book-cover-card" src="{{item.coverUrl || '/images/default-cover.png'}}" mode="aspectFill"></image>
        <text class="book-card-title">{{item.title}}</text>
        <text class="book-card-author">{{item.author}}</text>
      </view>
    </scroll-view>
  </view>

  <!-- My Books Section -->
  <view class="section my-books-section" wx:if="{{myBorrows.length > 0}}">
    <view class="section-head">
      <text class="section-title">My books</text>
    </view>
    <view class="my-book-card" wx:for="{{myBorrows}}" wx:key="id" bindtap="goDetail" data-id="{{item.book.id}}">
      <image class="my-book-cover" src="{{item.book.coverUrl || '/images/default-cover.png'}}" mode="aspectFill"></image>
      <view class="my-book-info">
        <text class="my-book-title">{{item.book.title}}</text>
        <text class="my-book-author">{{item.book.author}}</text>
        <text class="my-book-due {{item.isOverdue ? 'overdue' : ''}}">Return until {{item.dueDateStr}}</text>
      </view>
      <text class="my-book-dots">⋮</text>
    </view>
  </view>

  <view class="empty-text" wx:if="{{!loading && hotBooks.length === 0 && newArrivals.length === 0}}">
    No books available yet
  </view>
</view>
