.admin-books-container {
  padding: 24rpx;
  padding-bottom: 40rpx;
}

.toolbar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.search-wrap {
  flex: 1;
  position: relative;
}

.search-wrap .search-input {
  width: 100%;
  height: 72rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 0 60rpx 0 24rpx;
  font-size: 28rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  box-sizing: border-box;
}

.search-clear {
  position: absolute;
  right: 16rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

.add-btn {
  height: 72rpx;
  line-height: 72rpx;
  white-space: nowrap;
}

.status-tabs {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
}

.status-tabs .tab-item {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 26rpx;
  color: #666;
  position: relative;
}

.status-tabs .tab-item.active {
  color: #4A90D9;
  font-weight: 600;
}

.status-tabs .tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: #4A90D9;
  border-radius: 2rpx;
}

.category-scroll {
  white-space: nowrap;
  margin-bottom: 16rpx;
}

.category-tags {
  display: inline-flex;
  gap: 12rpx;
  padding: 4rpx 0;
}

.category-tag {
  display: inline-block;
  padding: 10rpx 24rpx;
  background: #fff;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #666;
  flex-shrink: 0;
}

.category-tag.active {
  background: #4A90D9;
  color: #fff;
}

.sort-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.result-count {
  font-size: 24rpx;
  color: #999;
}

.sort-buttons {
  display: flex;
  gap: 16rpx;
}

.sort-btn {
  font-size: 24rpx;
  color: #666;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  background: #fff;
}

.sort-btn.active {
  color: #4A90D9;
  font-weight: 600;
  background: #f0f4ff;
}

.book-item {
  padding: 20rpx 24rpx;
}

.book-row {
  display: flex;
  align-items: center;
}

.book-main {
  flex: 1;
  min-width: 0;
}

.book-title {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: #1a1a1a;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.book-sub {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 4rpx;
}

.book-stock {
  display: block;
  font-size: 22rpx;
  color: #666;
}

.book-actions {
  display: flex;
  gap: 20rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.action-edit {
  font-size: 26rpx;
  color: #4A90D9;
}

.action-delete {
  font-size: 26rpx;
  color: #ff4d4f;
}

.bottom-tip {
  text-align: center;
  color: #ccc;
  padding: 24rpx;
  font-size: 24rpx;
}
