.my-borrows-container {
  padding: 24rpx;
  padding-bottom: 40rpx;
}

.user-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.user-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #e8e8e8;
  margin-right: 20rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.user-role {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.filter-tabs {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 26rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #4A90D9;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: #4A90D9;
  border-radius: 2rpx;
}

.record-card {
  margin-bottom: 16rpx;
}

.record-book {
  display: flex;
  align-items: flex-start;
}

.record-cover {
  width: 120rpx;
  height: 160rpx;
  border-radius: 8rpx;
  background: #e8e8e8;
  flex-shrink: 0;
}

.record-info {
  flex: 1;
  margin-left: 20rpx;
}

.record-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 4rpx;
}

.record-author {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.record-dates {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.record-date {
  font-size: 22rpx;
  color: #999;
}

.record-status {
  flex-shrink: 0;
  margin-left: 12rpx;
}

.logout-section {
  margin-top: 60rpx;
}

.logout-btn {
  background: #fff;
  color: #ff4d4f;
  font-size: 30rpx;
  border-radius: 12rpx;
  border: 2rpx solid #ff4d4f;
}

.logout-btn::after {
  border: none;
}
