<view class="my-borrows-container">
  <view class="user-header card" wx:if="{{userInfo}}">
    <image class="user-avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}"></image>
    <view class="user-info">
      <text class="user-name">{{userInfo.name}}</text>
      <text class="user-role">{{userInfo.role === 'ADMIN' ? i18n.admin : i18n.user}}</text>
    </view>
    <view class="user-actions" wx:if="{{userInfo.role === 'ADMIN'}}">
      <button class="btn-secondary" size="mini" bindtap="goAdmin">{{i18n.adminPanel}}</button>
    </view>
  </view>

  <view class="filter-tabs">
    <view class="tab-item {{currentTab === 'all' ? 'active' : ''}}" bindtap="switchTab" data-tab="all">{{i18n.all}}</view>
    <view class="tab-item {{currentTab === 'BORROWED' ? 'active' : ''}}" bindtap="switchTab" data-tab="BORROWED">{{i18n.borrowed}}</view>
    <view class="tab-item {{currentTab === 'RETURNED' ? 'active' : ''}}" bindtap="switchTab" data-tab="RETURNED">{{i18n.returned}}</view>
    <view class="tab-item {{currentTab === 'OVERDUE' ? 'active' : ''}}" bindtap="switchTab" data-tab="OVERDUE">{{i18n.overdue}}</view>
  </view>

  <view class="record-list">
    <view class="record-card card" wx:for="{{records}}" wx:key="id">
      <view class="record-book" bindtap="goDetail" data-id="{{item.book.id}}">
        <image class="record-cover" src="{{item.book.coverUrl || '/images/default-cover.png'}}" mode="aspectFill"></image>
        <view class="record-info">
          <text class="record-title">{{item.book.title}}</text>
          <text class="record-author">{{item.book.author}}</text>
          <view class="record-dates">
            <text class="record-date">{{i18n.borrowDate}}{{item.borrowDateStr}}</text>
            <text class="record-date">{{i18n.dueDate}}{{item.dueDateStr}}</text>
            <text class="record-date" wx:if="{{item.returnDate}}">{{i18n.returnDate}}{{item.returnDateStr}}</text>
          </view>
        </view>
        <view class="record-status">
          <text class="tag {{item.statusClass}}">{{item.statusText}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="loading-text" wx:if="{{loading}}">{{i18n.loading}}</view>
  <view class="empty-text" wx:if="{{!loading && records.length === 0}}">{{i18n.noRecords}}</view>

  <view class="logout-section">
    <button class="logout-btn" bindtap="handleLogout">{{i18n.logout}}</button>
  </view>
</view>
