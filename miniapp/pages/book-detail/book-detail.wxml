<view class="detail-container" wx:if="{{book}}">
  <!-- Cover Hero -->
  <view class="cover-hero">
    <view class="cover-stage">
      <image class="detail-cover" src="{{book.coverUrl || '/images/default-cover.png'}}" mode="aspectFill"></image>
    </view>
  </view>

  <!-- Book Info - Centered -->
  <view class="book-main-info">
    <text class="detail-title">{{book.title}}</text>
    <text class="detail-author">{{book.author}}</text>

    <!-- Stock Progress Bar -->
    <view class="stock-bar-wrap">
      <view class="stock-bar-bg">
        <view class="stock-bar-fill {{book.availableCount > 0 ? '' : 'empty'}}" style="width: {{book.totalCount > 0 ? (book.availableCount / book.totalCount * 100) : 0}}%"></view>
      </view>
      <text class="stock-text {{book.availableCount > 0 ? 'in-stock' : 'out-stock'}}">{{book.availableCount > 0 ? 'In Stock' : 'Unavailable'}}</text>
    </view>
  </view>

  <!-- Description -->
  <view class="desc-section" wx:if="{{book.description}}">
    <text class="desc-text">{{book.description}}</text>
  </view>

  <!-- Detail Cards -->
  <view class="info-cards">
    <view class="info-row" wx:if="{{book.publisher}}">
      <text class="info-label">Publisher</text>
      <text class="info-value">{{book.publisher}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">Category</text>
      <text class="info-value">{{book.category ? book.category.name : 'Uncategorized'}}</text>
    </view>
    <view class="info-row" wx:if="{{book.isbn}}">
      <text class="info-label">ISBN</text>
      <text class="info-value">{{book.isbn}}</text>
    </view>
    <view class="info-row" wx:if="{{book.location}}">
      <text class="info-label">Location</text>
      <text class="info-value">{{book.location}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">Stock</text>
      <text class="info-value">{{book.availableCount}} / {{book.totalCount}}</text>
    </view>
  </view>

  <!-- Borrow Button -->
  <view class="detail-footer" wx:if="{{book.availableCount > 0 && book.status === 'AVAILABLE'}}">
    <button class="borrow-btn" bindtap="handleBorrow" loading="{{borrowing}}">Get the Book</button>
  </view>
  <view class="detail-footer" wx:elif="{{book.availableCount <= 0}}">
    <button class="borrow-btn disabled" disabled>Currently Unavailable</button>
  </view>
</view>
