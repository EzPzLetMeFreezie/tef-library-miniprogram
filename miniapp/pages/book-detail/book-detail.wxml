<view class="detail-container" wx:if="{{book}}">
  <view class="detail-header">
    <image class="detail-cover" src="{{book.coverUrl || '/images/default-cover.png'}}" mode="aspectFill"></image>
    <view class="detail-info">
      <text class="detail-title">{{book.title}}</text>
      <text class="detail-author">{{book.author}}</text>
      <text class="detail-publisher" wx:if="{{book.publisher}}">{{book.publisher}}</text>
      <view class="detail-meta">
        <text class="tag {{book.availableCount > 0 ? 'tag-available' : 'tag-overdue'}}">
          {{book.availableCount > 0 ? '可借阅' : '已借完'}}
        </text>
        <text class="detail-stock">库存 {{book.availableCount}}/{{book.totalCount}}</text>
      </view>
    </view>
  </view>

  <view class="card detail-section">
    <text class="section-label">分类</text>
    <text class="section-value">{{book.category ? book.category.name : '未分类'}}</text>
  </view>

  <view class="card detail-section" wx:if="{{book.isbn}}">
    <text class="section-label">ISBN</text>
    <text class="section-value">{{book.isbn}}</text>
  </view>

  <view class="card detail-section" wx:if="{{book.location}}">
    <text class="section-label">位置</text>
    <text class="section-value">{{book.location}}</text>
  </view>

  <view class="card detail-desc" wx:if="{{book.description}}">
    <text class="section-label">简介</text>
    <text class="desc-text">{{book.description}}</text>
  </view>

  <view class="detail-footer" wx:if="{{book.availableCount > 0 && book.status === 'AVAILABLE'}}">
    <button class="btn-primary borrow-btn" bindtap="handleBorrow" loading="{{borrowing}}">借阅此书</button>
  </view>
</view>
