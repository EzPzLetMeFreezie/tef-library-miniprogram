.detail-container {
  padding: 24rpx;
  padding-bottom: 160rpx;
}

.detail-header {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.detail-cover {
  width: 220rpx;
  height: 300rpx;
  border-radius: 12rpx;
  background: #e8e8e8;
  flex-shrink: 0;
}

.detail-info {
  flex: 1;
  margin-left: 28rpx;
  display: flex;
  flex-direction: column;
}

.detail-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 12rpx;
}

.detail-author {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.detail-publisher {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.detail-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: auto;
}

.detail-stock {
  font-size: 24rpx;
  color: #999;
}

.detail-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.section-label {
  font-size: 28rpx;
  color: #999;
}

.section-value {
  font-size: 28rpx;
  color: #333;
}

.detail-desc {
  flex-direction: column;
}

.desc-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
  margin-top: 12rpx;
}

.detail-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.borrow-btn {
  width: 100%;
}
