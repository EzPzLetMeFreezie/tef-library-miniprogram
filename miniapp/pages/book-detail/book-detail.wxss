.detail-container {
  padding-bottom: 160rpx;
  background: #fff;
  min-height: 100vh;
}

/* Cover Hero */
.cover-hero {
  display: flex;
  justify-content: center;
  padding: 40rpx 0 32rpx;
  background: #f2f2f2;
}

.cover-stage {
  position: relative;
}

.detail-cover {
  width: 320rpx;
  height: 440rpx;
  border-radius: 12rpx;
  background: #e0e0e0;
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.15);
}

/* Book Main Info */
.book-main-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 36rpx 48rpx 24rpx;
}

.detail-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
  text-align: center;
  line-height: 1.3;
}

.detail-author {
  font-size: 28rpx;
  color: #888;
  margin-top: 12rpx;
  text-align: center;
}

/* Stock Bar */
.stock-bar-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 28rpx;
}

.stock-bar-bg {
  width: 160rpx;
  height: 8rpx;
  background: #e0e0e0;
  border-radius: 4rpx;
  overflow: hidden;
}

.stock-bar-fill {
  height: 100%;
  background: #4CAF50;
  border-radius: 4rpx;
  transition: width 0.3s;
}

.stock-bar-fill.empty {
  background: #ff4d4f;
}

.stock-text {
  font-size: 24rpx;
  font-weight: 500;
}

.stock-text.in-stock {
  color: #4CAF50;
}

.stock-text.out-stock {
  color: #ff4d4f;
}

/* Description */
.desc-section {
  padding: 16rpx 48rpx 24rpx;
}

.desc-text {
  font-size: 26rpx;
  color: #888;
  line-height: 1.8;
  text-align: center;
}

/* Info Cards */
.info-cards {
  margin: 16rpx 32rpx;
  background: #f9f9f9;
  border-radius: 16rpx;
  padding: 8rpx 28rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: #999;
}

.info-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

/* Footer */
.detail-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 40rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
}

.borrow-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  background: #1a1a1a;
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  letter-spacing: 2rpx;
}

.borrow-btn::after {
  border: none;
}

.borrow-btn.disabled {
  background: #ccc;
  color: #999;
}
