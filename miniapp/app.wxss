page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  color: #333;
  background-color: #f5f6fa;
  line-height: 1.6;
}

.container {
  padding: 24rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.btn-primary {
  background: linear-gradient(135deg, #4A90D9, #357ABD);
  color: #fff;
  border: none;
  border-radius: 12rpx;
  padding: 20rpx 40rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background: #f0f4ff;
  color: #4A90D9;
  border: none;
  border-radius: 12rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
}

.btn-danger {
  background: #ff4d4f;
  color: #fff;
  border: none;
  border-radius: 12rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 20rpx;
}

.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.tag-borrowed {
  background: #fff7e6;
  color: #fa8c16;
}

.tag-returned {
  background: #f6ffed;
  color: #52c41a;
}

.tag-overdue {
  background: #fff2f0;
  color: #ff4d4f;
}

.tag-available {
  background: #e6f7ff;
  color: #1890ff;
}

.empty-text {
  text-align: center;
  color: #999;
  padding: 80rpx 0;
  font-size: 28rpx;
}

.loading-text {
  text-align: center;
  color: #999;
  padding: 40rpx 0;
  font-size: 26rpx;
}
